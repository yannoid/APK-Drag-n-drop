<Window x:Class="ApkDragNDrop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ApkDragNDrop.Models"
        xmlns:conv="clr-namespace:ApkDragNDrop.Converters"
        Title="APK Drag'n'drop"
        Width="380" Height="560"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Icon="Assets/app.ico">

    <Window.Resources>
        <conv:DeviceStateToBrushConverter x:Key="DeviceStateToBrush"/>
        <conv:JobStatusToBrushConverter x:Key="JobStatusToBrush"/>
    </Window.Resources>

    <Border CornerRadius="18" Background="{StaticResource WindowBg}" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.35" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetName="BlobATransform" Storyboard.TargetProperty="X"
                                             From="-20" To="20" Duration="0:0:14">
                                <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="BlobATransform" Storyboard.TargetProperty="Y"
                                             From="-15" To="15" Duration="0:0:14">
                                <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="BlobBTransform" Storyboard.TargetProperty="X"
                                             From="15" To="-25" Duration="0:0:18">
                                <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="BlobBTransform" Storyboard.TargetProperty="Y"
                                             From="10" To="-20" Duration="0:0:18">
                                <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="BlobCTransform" Storyboard.TargetProperty="ScaleX"
                                             From="0.9" To="1.1" Duration="0:0:9">
                                <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="BlobCTransform" Storyboard.TargetProperty="ScaleY"
                                             From="0.9" To="1.1" Duration="0:0:9">
                                <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
            <!-- Animated liquid background blobs -->
            <Canvas x:Name="BlobLayer">
                <Ellipse x:Name="BlobA" Width="260" Height="260" Canvas.Left="-80" Canvas.Top="-60" Opacity="0.5">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="BlobATransform"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Effect>
                        <BlurEffect Radius="60"/>
                    </Ellipse.Effect>
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#3B5BFF" Offset="0"/>
                            <GradientStop Color="#003B5BFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse x:Name="BlobB" Width="300" Height="300" Canvas.Left="140" Canvas.Top="280" Opacity="0.4">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="BlobBTransform"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Effect>
                        <BlurEffect Radius="60"/>
                    </Ellipse.Effect>
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#8A4BFF" Offset="0"/>
                            <GradientStop Color="#008A4BFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse x:Name="BlobC" Width="180" Height="180" Canvas.Left="60" Canvas.Top="120" Opacity="0.3">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="BlobCTransform" CenterX="90" CenterY="90"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Effect>
                        <BlurEffect Radius="60"/>
                    </Ellipse.Effect>
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#26C9AE" Offset="0"/>
                            <GradientStop Color="#0026C9AE" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>

            <!-- Content -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto" MaxHeight="150"/>
                    <RowDefinition Height="64"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Grid Grid.Row="0" Margin="12,0,8,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="Assets/app.ico" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="APK Drag'n'drop" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Style="{StaticResource CloseButton}" Content="—" Click="MinimizeButton_Click" Margin="0,0,4,0"/>
                    <Button Grid.Column="3" Style="{StaticResource CloseButton}" Content="✕" Click="CloseButton_Click"/>
                </Grid>

                <!-- Device selector row -->
                <Grid Grid.Row="1" Margin="16,12,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ToggleButton x:Name="DeviceToggle" Grid.Column="0" Style="{StaticResource GlassPillToggle}"
                                  HorizontalContentAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DeviceSummaryText" Grid.Column="0" Text="Aucun appareil"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1" Text="▾" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </ToggleButton>

                    <Button x:Name="RefreshButton" Grid.Column="1" Style="{StaticResource CircleButton}"
                            Margin="8,0,0,0" Click="RefreshButton_Click" ToolTip="Rafraîchir la liste des appareils">
                        <TextBlock x:Name="RefreshIcon" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="15" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="RefreshRotation"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>

                    <Popup x:Name="DevicesPopup" PlacementTarget="{Binding ElementName=DeviceToggle}"
                           IsOpen="{Binding IsChecked, ElementName=DeviceToggle}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Style="{StaticResource GlassPanel}" CornerRadius="12" Background="#E61E2230"
                                Width="280" MaxHeight="240" Margin="0,4,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240">
                                <ItemsControl x:Name="DevicesItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:DeviceInfo}">
                                            <Grid Height="40" Margin="8,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          IsEnabled="{Binding IsUsable}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <Ellipse Grid.Column="1" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                                                         Fill="{Binding State, Converter={StaticResource DeviceStateToBrush}}"/>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayModel}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="10">
                                                        <Run Text="{Binding Serial, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding StatusText, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Drop zone + apk queue -->
                <Grid Grid.Row="2" Margin="16,0,16,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" MinHeight="90"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="DropZoneBorder" Grid.Row="0" Style="{StaticResource GlassPanel}" CornerRadius="16"
                            AllowDrop="True" Drop="DropZone_Drop" DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave"
                            DragOver="DropZone_DragOver" MouseLeftButtonUp="DropZone_MouseLeftButtonUp" Cursor="Hand" Padding="16">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x2B07;" FontSize="26" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Glissez vos fichiers .apk ici" FontSize="13" Margin="0,6,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="ou cliquez pour parcourir" FontSize="11" Margin="0,2,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                        <ItemsControl x:Name="ApkQueueItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ApkQueueItem}">
                                    <Border Height="40" CornerRadius="10" Margin="0,3,0,0" Background="{StaticResource GlassPanelBrush}">
                                        <Grid Margin="10,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SizeText}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="✕" Width="20" Height="20" Padding="0"
                                                    Click="RemoveApk_Click" Tag="{Binding}"
                                                    Style="{StaticResource CloseButton}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Install queue / progress -->
                <Border x:Name="JobsPanel" Grid.Row="3" Style="{StaticResource GlassPanel}" Margin="16,0,16,8" Padding="8" Visibility="Collapsed">
                    <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="JobsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:InstallJob}">
                                    <Grid Height="32" Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Fill="{Binding Status, Converter={StaticResource JobStatusToBrush}}"/>
                                        <TextBlock Grid.Column="1" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding ApkFileName, Mode=OneWay}"/>
                                            <Run Text=" → "/>
                                            <Run Text="{Binding TargetDevice.DisplayModel, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="10"
                                                   VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"
                                                   ToolTip="{Binding ResultMessage}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Send button -->
                <Button x:Name="SendButton" Grid.Row="4" Style="{StaticResource AccentPillButton}"
                        Margin="16,0,16,16" IsEnabled="False" Click="SendButton_Click">
                    <TextBlock x:Name="SendButtonText" Text="Envoyer"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
